{
  "name": "rad-codegraph",
  "version": "0.1.0",
  "description": "CodeGraph CLI guidance for Pi Agent — injects usage hints when .codegraph index is present.",
  "license": "MIT",
  "type": "module",
  "files": [
    "extensions"
  ],
	"exports": {
		"./extensions": "./extensions/index.ts"
	},
  "pi": {
